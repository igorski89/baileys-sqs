    "@hapi/boom": "^10.0.1",
    "@cacheable/node-cache": "^1.5.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.2.2",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
