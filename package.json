{
  "name": "baileys-sqs",
  "version": "1.0.0",
  "description": "Baileys SQS connector",
  "keywords": [
    "baileys",
    "sqs",
    "whatsapp",
    "aws",
    "queue"
  ],
  "license": "MIT",
  "author": "Igor Ievsiukov <igor.ievsiukov@gmail.com>",
  "type": "module",
