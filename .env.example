# ============================================
# AWS Configuration
# ============================================

# AWS Region where your SQS queue is located
# Examples: us-east-1, eu-west-1, ap-southeast-1
AWS_REGION=us-east-1

# AWS Access Key ID for authentication
# Get this from AWS IAM Console
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# AWS Secret Access Key for authentication
# Keep this secure and never commit to version control
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Optional: AWS Session Token (only if using temporary credentials)
# AWS_SESSION_TOKEN=your_session_token

# ============================================
# SQS Configuration
# ============================================

# Input Queue - Messages to be sent to WhatsApp
# Format: https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>
SQS_INPUT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/input-queue

# Output Queue - Messages received from WhatsApp
SQS_OUTPUT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/output-queue

# Optional: Message visibility timeout in seconds (default: 30)
# SQS_VISIBILITY_TIMEOUT=30

# Optional: Long polling wait time in seconds for input queue (default: 20)
# Set to 1-20 to enable long polling and reduce costs
# SQS_WAIT_TIME_SECONDS=20

# Optional: Maximum number of messages to receive per request (default: 10)
# SQS_MAX_NUMBER_OF_MESSAGES=10

# ============================================
# Baileys/WhatsApp Configuration
# ============================================

# Directory to store authentication credentials
# This directory is automatically created and should be persisted
# between container restarts to avoid re-authentication
AUTH_DIRECTORY=./auth_info_baileys

# Optional: Name of the WhatsApp session
# SESSION_NAME=baileys-sqs-session

# Optional: Enable logging level (trace, debug, info, warn, error, fatal, silent)
# Default: info
# LOG_LEVEL=info

# Optional: Browser platform identifier sent to WhatsApp
# Options: macOS, Windows, Ubuntu, Linux
# BROWSER_PLATFORM=Ubuntu

# ============================================
# Application Configuration
# ============================================

# Node environment (development, production, test)
NODE_ENV=production

# Optional: Port for health check endpoint (if implemented)
# PORT=3000

# Optional: Enable/disable QR code display in terminal
# Values: true, false
# SHOW_QR_TERMINAL=true

# ============================================
# Advanced/Optional Settings
# ============================================

# Optional: AWS endpoint URL (for LocalStack/local testing)
# AWS_ENDPOINT_URL=http://localhost:4566

# Optional: Message processing concurrency limit
# CONCURRENCY_LIMIT=5

# Optional: Maximum retry attempts for failed messages
# MAX_RETRY_ATTEMPTS=3
