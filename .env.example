# ============================================
# AWS Configuration
# ============================================

# AWS Region where your SQS queue is located
# Examples: us-east-1, eu-west-1, ap-southeast-1
AWS_REGION=us-east-1

# AWS Access Key ID for authentication
# Get this from AWS IAM Console
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# AWS Secret Access Key for authentication
# Keep this secure and never commit to version control
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Optional: AWS Session Token (only if using temporary credentials)
# AWS_SESSION_TOKEN=your_session_token

# Optional: AWS endpoint URL (for LocalStack/ElasticMQ local testing)
# AWS_ENDPOINT_URL=http://localhost:4566

# ============================================
# SQS Configuration
# ============================================

# Input Queue - Messages to be sent to WhatsApp (required)
# Format: https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>
INPUT_QUEUE=https://sqs.us-east-1.amazonaws.com/123456789012/input-queue

# Output Queue - Messages received from WhatsApp (required)
# Format: https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>
OUTPUT_QUEUE=https://sqs.us-east-1.amazonaws.com/123456789012/output-queue

# ============================================
# Baileys/WhatsApp Configuration
# ============================================

# Directory to store authentication credentials
# This directory is automatically created and should be persisted
# between container restarts to avoid re-authentication
# Default: ./auth
SESSION_DIR=./auth_info_baileys

# Optional: Encode media attachments as base64 in outgoing messages
# Set to "false" to disable base64 encoding and improve performance
# Default: true
# BASE64_MEDIA=true

# Optional: Comma-separated list of events to listen to
# Use "*" for all events, or specify: messages.upsert,messages.update,connection.update
# Default: *
# LISTEN_EVENTS=*

# ============================================
# Application Configuration
# ============================================

# Node environment (development, production, test)
NODE_ENV=production

# Optional: Enable debug logging in listener script
# Set to "true" to see full event payloads
# DEBUG=false
